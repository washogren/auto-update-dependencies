{
  "name": "auto-update-dependencies",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action that resolves an npm dist-tag, bumps a consumer's package.json, and emits a rich PR body (commits + grouped PRs) to feed peter-evans/create-pull-request.",
  "license": "MIT",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/index.js",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^8.0.1"
  },
  "overrides": {
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/eslint-plugin": "^1.6.20",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "yaml": "^2.9.0"
  }
}
